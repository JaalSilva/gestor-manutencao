{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Athlete in the league",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "congregation": { "type": "string" },
        "age": { "type": "integer" },
        "status_payment": { "type": "string", "enum": ["PAGO", "PENDENTE"] },
        "payment_date": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "phone"]
    },
    "Sender": {
      "title": "Sender",
      "description": "Authorized message sender",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["CONECTADO", "DESCONECTADO"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Player attendance record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "player_id": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["PRESENTE", "AUSENTE", "JUSTIFICADO"] },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "FairPlay": {
      "title": "FairPlay",
      "description": "Fair Play and ranking event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "player_id": { "type": "string" },
        "score": { "type": "integer" },
        "reason": { "type": "string" },
        "category": { "type": "string", "enum": ["PRESENCA", "PAGAMENTO", "COMPORTAMENTO", "ADVERTENCIA", "GOL", "ASSISTENCIA"] },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Match": {
      "title": "Match",
      "description": "Soccer match record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "team_a_score": { "type": "integer" },
        "team_b_score": { "type": "integer" },
        "notes": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "AppSetting": {
      "title": "AppSetting",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" }
      }
    },
    "BillingLog": {
      "title": "BillingLog",
      "description": "Log of a billing attempt",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "player_id": { "type": "string" },
        "sender_id": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string" },
        "message": { "type": "string" },
        "error_details": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "SystemLog": {
      "title": "SystemLog",
      "description": "Critical operation audit log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "operation": { "type": "string" },
        "entity": { "type": "string" },
        "entity_id": { "type": "string" },
        "details": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/players": { "schema": "Player", "description": "Athletes list" },
    "/senders": { "schema": "Sender", "description": "Message senders" },
    "/attendance": { "schema": "Attendance", "description": "Attendance logs" },
    "/fair_play": { "schema": "FairPlay", "description": "Ranking points" },
    "/matches": { "schema": "Match", "description": "Match history" },
    "/app_settings": { "schema": "AppSetting", "description": "App configuration" },
    "/billing_logs": { "schema": "BillingLog", "description": "Billing activity" },
    "/match_session": { "schema": "object", "description": "Current timer state" },
    "/system_logs": { "schema": "SystemLog", "description": "Audit trails" }
  }
}
