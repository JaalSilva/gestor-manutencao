{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account for authentication",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "login": { "type": "string" },
        "password": { "type": "string", "description": "AES-256 encrypted password or hash" },
        "role": { "type": "string" }
      },
      "required": ["login", "password"]
    },
    "Settings": {
      "title": "Application Settings",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "appName": { "type": "string" },
        "primaryColor": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "darkMode": { "type": "boolean" },
        "commissionMembers": { "type": "array" }
      }
    },
    "Panel": {
      "title": "Maintenance Panel",
      "description": "Operational panel with teams",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "teams": { "type": "array" },
        "updatedAt": { "type": "string" }
      }
    },
    "TaskDefinition": {
      "title": "Task Definition",
      "description": "Technical maintenance data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "frequency": { "type": "string" },
        "periodsPerYear": { "type": "integer" }
      }
    },
    "Task": {
      "title": "Maintenance Task",
      "description": "Executed maintenance record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "definitionId": { "type": "string" },
        "periodIndex": { "type": "integer" },
        "year": { "type": "integer" },
        "status": { "type": "string" },
        "completedAt": { "type": "string" }
      }
    },
    "Pendency": {
      "title": "Maintenance Pendency",
      "description": "Corrective maintenance pending",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporter": { "type": "string" },
        "area": { "type": "string" },
        "criticality": { "type": "string" },
        "cost": { "type": "number" },
        "description": { "type": "string" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User accounts" },
    "panels": { "schema": "Panel", "description": "Operational panels" },
    "taskDefinitions": { "schema": "TaskDefinition", "description": "Technical library" },
    "tasks": { "schema": "Task", "description": "Execution history" },
    "pendencies": { "schema": "Pendency", "description": "Pending issues" },
    "transactions": { "schema": "Transaction", "description": "Treasury records" },
    "config/settings": { "schema": "Settings", "description": "Global settings" }
  }
}
